{
  "expo": {
    "name": "DengueSense BD",
    "slug": "denguesense-bd",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "favicon": "./assets/favicon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A6B3A"
    },
    "android": {
      "package": "bd.bsia.denguesense",
      "versionCode": 1,
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "scheme": "denguesense",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe572fac-9844-4eae-a28b-7cf6fa19b6d1"
      },
      "apiUrl": "https://denguesense-backend-1.onrender.com"
    },
    "owner": "jb1010",
    "ios": {
      "bundleIdentifier": "bd.bsia.denguesense",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
